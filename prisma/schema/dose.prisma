model Dose {
  id     String @id @default(cuid())
  userId String // Connects to your User model

  // Basic Info
  doseName     String
  medicineType MedicineType
  slotType     SlotType
  colorCode    String       @default("#4A90E2")
  notes        String?      @db.Text

  // Pill Tracking
  totalPills     Int     @default(0)
  takenPills     Int     @default(0)
  remainingPills Int     @default(0)
  doseAmount     String?

  // Schedule & Timing
  startDate     DateTime?
  endDate       DateTime?
  medicineTimes String[] // Stored as array of time strings (e.g., ["08:00", "20:00"])

  timezone String @default("UTC")

  // Status & Notifications
  isActive            Boolean @default(true)
  notificationEnabled Boolean @default(false)
  notificationSent    Boolean @default(false) @map("notificationSentForCurrentSlot")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, isActive])
  @@map("doses")
}

enum MedicineType {
  PILL
  CAPSULE
}

enum SlotType {
  SMALL
  MEDIUM
  LARGE
}
